# Terraform working directory
.terraform/

# Terraform state files (VERY IMPORTANT — contains secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Lock file (optional: keep or ignore depending on team)
.terraform.lock.hcl

# Private keys (you have one!)
*.pem
*.key

# OS / editor junk
.DS_Store
.vscode/